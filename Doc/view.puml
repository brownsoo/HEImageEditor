@startuml HiEffectImage

page 2x4
skinparam PageMargin 10
skinparam PackageStyle rectangle

package "HEImageEditor" {
    interface HEImageEditor {}
    
     
}

package "HEImageEditor.Type" {
    '  /// 편집 정보
    class HEEditState {
        + drawPaths: [HEDrawPath]
        + mosaicPaths: [HEMosaicPath]
        + clipStatus: HEClipStatus?
        + adjustStatus: HEAdjustStatus
        + selectFilter: HEFilter?
        스티커 정보
        + stickers: [HEStickerEffect]
        + actions: [HEEditAction]
        
        편집 정보들을 합쳐 이미지를 재생성했는 지 체크 
        + fattened: Bool
    }  
}

package "HEImageEditor.EditView" {
    
    interface HEEditImageView {
        // 선택된 편집 툴
        + selectedTool: HEImageEditorConfiguration.EditTool? { get }
        /// 편집 중
        + isImageEditing: Bool { get }
        ==
        /// 취소하고 화면 종료
        + cancel()
        /// 편집된 이미지 생성하고 화면 종료
        + done()
        /// 자르기, 회전 시작
        + startClipping()
        /// 이미지 스티커 시작
        + startImageSticker()
        /// 텍스트 스티커 시작
        + startTextSticker()
        /// 모자이크로 그리기 시작
        + startMosaicDrawing()
        /// 그리기 시작
        + startDrawing()
        /// 필터 시작
        + startFiltering()
        /// 색조 조정 시작 
        + startAdjusting()
        /// 편집 상황을 종료
        + stopCurrentEditing()
        -- undo, redo --
        /// 편집 행위 되돌리기
        + undo()
        /// 편집 행위 재실행
        + redo()
        /// 편집 행위 변경사항 리스너 추가
        + addActionChangedListener<T: HEEditorActionListener>(_ listener: T)
        /// 편집 행위 변경사항 리스너 제거
        + removeActionChangedListener<T: HEEditorActionListener>(_ listener: T)
        /// 편집 행위 변경사항 모든 리스너 제거
        + clearAllActionChangedListeners()
    }

    class HEEditImageViewController implements HEEditImageView {
    }
    
    class HEClipImageViewController {}
    
    class HEEditActionManager {}
}

HEImageEditor.HEImageEditor <-- HEEditImageViewController

package "HEImageEditor.Configuration" {
    struct HEEditorWordings {
        // 메시지 문자 세트
        
    }
}



@enduml
